{
  "datasets": [
    {
      "name": "1844bc79",
      "displayName": "daily_cost_trend",
      "queryLines": [
        "SELECT\r\n",
        "    event_date,\r\n",
        "    team,\r\n",
        "    total_cost_usd,\r\n",
        "    rolling_7d_avg_cost,\r\n",
        "    total_calls\r\n",
        "FROM llm_pulse_dev.gold.daily_cost_by_team\r\n",
        "ORDER BY event_date"
      ]
    },
    {
      "name": "a40a6bda",
      "displayName": "Model Performance Cost and Metrics Summary",
      "queryLines": [
        "SELECT\r\n",
        "    model,\r\n",
        "    ROUND(SUM(total_cost_usd), 2)   AS total_spend_usd,\r\n",
        "    SUM(total_calls)                AS total_calls,\r\n",
        "    ROUND(AVG(error_rate_pct), 2)   AS avg_error_rate_pct,\r\n",
        "    ROUND(AVG(avg_latency_ms), 0)   AS avg_latency_ms\r\n",
        "FROM llm_pulse_dev.gold.model_performance_summary\r\n",
        "GROUP BY model\r\n",
        "ORDER BY total_spend_usd DESC"
      ]
    },
    {
      "name": "4ca0082c",
      "displayName": "Top Features and Teams by Cost and Calls Summary",
      "queryLines": [
        "SELECT\r\n",
        "    feature,\r\n",
        "    team,\r\n",
        "    ROUND(SUM(total_cost_usd), 2) AS total_spend_usd,\r\n",
        "    SUM(total_calls)              AS total_calls\r\n",
        "FROM llm_pulse_dev.gold.feature_cost_breakdown\r\n",
        "GROUP BY feature, team\r\n",
        "ORDER BY total_spend_usd DESC\r\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "31597fff",
      "displayName": "Model Quality Scores and Trends Over Time",
      "queryLines": [
        "SELECT\r\n",
        "    feedback_date,\r\n",
        "    model,\r\n",
        "    AVG(quality_score_pct)          AS avg_quality_score,\r\n",
        "    AVG(rolling_7d_quality_score)   AS avg_rolling_quality\r\n",
        "FROM llm_pulse_dev.gold.quality_score_daily\r\n",
        "GROUP BY feedback_date, model\r\n",
        "ORDER BY feedback_date"
      ]
    },
    {
      "name": "dc6b9b9f",
      "displayName": "Forecasted Team Cost Estimates by Prediction Date",
      "queryLines": [
        "SELECT\r\n",
        "    prediction_date,\r\n",
        "    team,\r\n",
        "    predicted_cost_usd,\r\n",
        "    prediction_horizon_days\r\n",
        "FROM llm_pulse_dev.gold.cost_predictions\r\n",
        "ORDER BY prediction_date, team"
      ]
    },
    {
      "name": "05f7b5d0",
      "displayName": "Alert Type and Severity Summary Report",
      "queryLines": [
        "SELECT\r\n",
        "    alert_severity,\r\n",
        "    model,\r\n",
        "    COUNT(*)                        AS total_alerts,\r\n",
        "    MIN(feedback_date)              AS first_seen,\r\n",
        "    MAX(feedback_date)              AS last_seen\r\n",
        "FROM llm_pulse_dev.gold.quality_alerts\r\n",
        "GROUP BY alert_severity, model\r\n",
        "ORDER BY total_alerts DESC"
      ]
    },
    {
      "name": "09ac533c",
      "displayName": "Monthly Team Cost Summary in USD",
      "queryLines": [
        "SELECT ROUND(SUM(total_cost_usd), 2) AS total_spend_usd\r\n",
        "FROM llm_pulse_dev.gold.daily_cost_by_team\r\n",
        "WHERE event_date >= DATE_TRUNC('month', CURRENT_DATE())"
      ]
    },
    {
      "name": "0474bbd2",
      "displayName": "Aggregate Total Calls by Team Daily Summary",
      "queryLines": [
        "SELECT SUM(total_calls) AS total_calls\r\n",
        "FROM llm_pulse_dev.gold.daily_cost_by_team"
      ]
    },
    {
      "name": "045b978e",
      "displayName": "Count of High Severity Alerts Summary",
      "queryLines": [
        "SELECT COUNT(*) AS critical_alerts\r\n",
        "FROM llm_pulse_dev.gold.quality_alerts\r\n",
        "WHERE alert_severity = 'critical'"
      ]
    }
  ],
